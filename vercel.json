{
  "version": 2,
  "functions": {
    "*.php": { "runtime": "vercel-php@0.7.2" },
    "admin/*.php": { "runtime": "vercel-php@0.7.2" }
  },
  "routes": [
    { "src": "/admin", "dest": "/admin/index.php" },
    { "src": "/services", "dest": "/services.php" },
    { "src": "/booking", "dest": "/booking.php" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
